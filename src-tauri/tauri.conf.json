{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GotifyClient",
  "identifier": "com.gotify.client.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gotify 客户端",
        "width": 980,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520,
        "visible": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/defaultapp.png",
      "icons/defaultapp.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "both"
      }
    }
  }
}

